# github-runner/.env.example
# Copy this file to .env and fill in the required values.
# The .env file is git-ignored — never commit credentials.
#
# Usage:
#   cp .env.example .env
#   docker compose up
#   docker compose up --scale runner=3

# =============================================================================
# Authentication — provide exactly ONE of Option 0, Option A, or Option B
# =============================================================================

# Option 0: Direct registration token (from GitHub UI — simplest, expires in 1h)
# Repo: Settings → Actions → Runners → New self-hosted runner → copy the token
# Org:  Settings → Actions → Runners → New runner → copy the token
# RUNNER_TOKEN=AXXXXXXXXXXXXXXXXXX

# Option A: Personal Access Token
# Required scopes: repo (for repository runners) or admin:org (for org runners)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Option B: GitHub App
# Create a GitHub App with "Self-hosted runners" (read + write) permission.
# APP_PRIVATE_KEY accepts a PEM string with literal \n line separators.
# APP_ID=123456
# APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Alternatively, mount a PEM file and set APP_PRIVATE_KEY_FILE instead:
# APP_PRIVATE_KEY_FILE=/run/secrets/github-app.pem

# =============================================================================
# Scope — provide exactly ONE of repository or organization
# =============================================================================

# Register runner on a single repository
GITHUB_REPOSITORY=owner/repo

# Register runner at the organization level (all repos in the org)
# GITHUB_ORG=myorg

# =============================================================================
# Optional — runner identity and labeling
# =============================================================================

# Prefix used when generating the unique runner name: <prefix>-<hostname>-<epoch>
# RUNNER_NAME_PREFIX=local

# Comma-separated labels attached to the runner (queried by workflow `runs-on`)
# RUNNER_LABELS=self-hosted,linux

# Runner group (must exist in GitHub; defaults to "Default")
# RUNNER_GROUP=Default

# GitHub API base URL — override for GitHub Enterprise Server
# GITHUB_API_URL=https://github.example.com/api/v3

# =============================================================================
# Security
# =============================================================================

# Allow the runner to start as root (not recommended)
# Set to "true" only in isolated CI environments with no untrusted workflows.
# ALLOW_ROOT=false

# Docker daemon socket for DooD (Docker-outside-of-Docker).
# Only set if you have uncommented the socket volume mount in compose.yaml.
# DOCKER_HOST=unix:///var/run/docker.sock
